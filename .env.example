# Notion integration token (Notion -> Settings -> Connections -> Develop or manage integrations)
NOTION_API_KEY=

# Data source ID for the "Coaching Applications" Notion database
NOTION_DATABASE_ID=d9dbcdf8-6dce-4994-a50b-f8437c55a9fa

# Resend API key (resend.com -> API Keys)
RESEND_API_KEY=

# Verified-domain sender for outbound email (Resend). Required to email applicants —
# the Resend sandbox sender only delivers to your own account address. Falls back to
# onboarding@resend.dev if unset (owner notification only).
EMAIL_FROM=JR Fitness <no-reply@jrfitness.co.uk>

# Where new application notification emails are sent
NOTIFICATION_EMAIL=kuba@jrfitness.co.uk
